<% content_for :page_styles do %>
  <%= stylesheet_link_tag "auth", "data-turbo-track": "reload" %>
<% end %>

<main class="auth">
  <div class="auth__card">
    <%= image_tag "/logo_with_word.png", alt: "DevCine", class: "auth__logo" %>

    <% if @user.errors.any? %>
      <div class="form-flash form-flash-alert">
        <%= @user.errors.full_messages.first %>
      </div>
    <% end %>

    <%= form_with model: @user, url: registration_path, class: "auth__form",
          data: { controller: "password-confirmation" } do |form| %>
      <div class="field">
        <%= form.label :email_address, "Login", class: "field-label" %>
        <%= form.email_field :email_address, required: true, autofocus: true,
              autocomplete: "email", class: "field-input" %>
      </div>

      <div class="field">
        <%= form.label :password, "Senha", class: "field-label" %>
        <%= form.password_field :password, required: true,
              autocomplete: "new-password", maxlength: 72, class: "field-input",
              data: { "password-confirmation-target": "password",
                      action: "input->password-confirmation#check" } %>
      </div>

      <div class="field">
        <%= form.label :password_confirmation, "Confirme a Senha", class: "field-label" %>
        <%= form.password_field :password_confirmation, required: true,
              autocomplete: "new-password", maxlength: 72, class: "field-input",
              data: { "password-confirmation-target": "confirmation",
                      action: "input->password-confirmation#check" } %>
        <p class="field-error" data-password-confirmation-target="message"></p>
      </div>

      <%= form.submit "Create account", class: "btn btn-primary auth__submit",
            data: { "password-confirmation-target": "submit" } %>
    <% end %>

    <p class="auth__alt">
      Already have an account?
      <%= link_to "Sign In", new_session_path, class: "auth__link" %>
    </p>
  </div>
</main>
