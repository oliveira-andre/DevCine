<% content_for :page_styles do %>
  <%= stylesheet_link_tag "auth", "data-turbo-track": "dynamic" %>
<% end %>

<main class="auth">
  <div class="auth__card">
    <%= image_tag "/logo_with_word.png", alt: "DevCine", class: "auth__logo" %>

    <% if flash[:alert] %>
      <div class="form-flash form-flash-alert"><%= flash[:alert] %></div>
    <% end %>
    <% if flash[:notice] %>
      <div class="form-flash form-flash-notice"><%= flash[:notice] %></div>
    <% end %>

    <%= form_with url: session_path, class: "auth__form" do |form| %>
      <div class="field">
        <%= form.label :email_address, "Login", class: "field-label" %>
        <%= form.email_field :email_address, required: true, autofocus: true,
              autocomplete: "username", class: "field-input",
              value: params[:email_address] %>
      </div>

      <div class="field">
        <%= form.label :password, "Senha", class: "field-label" %>
        <%= form.password_field :password, required: true,
              autocomplete: "current-password", maxlength: 72, class: "field-input" %>
      </div>

      <%= form.submit "Login", class: "btn btn-primary auth__submit" %>
    <% end %>

    <p class="auth__alt">
      You don't have an account yet?
      <%= link_to "Sign Up", new_registration_path, class: "auth__link" %>
    </p>
    <p class="auth__alt">
      <%= link_to "Forgot your password?", new_password_path, class: "auth__link" %>
    </p>
  </div>
</main>
