<%= modal title: "Upload video", size: :wide do %>
  <%= form_with model: @video, url: videos_path, class: "modal__form upload-form" do |form| %>
    <% if @video.errors.any? %>
      <div class="form-flash form-flash-alert upload-form__flash"><%= @video.errors.full_messages.first %></div>
    <% end %>

    <div class="upload-form__grid">
      <%# Left: metadata fields %>
      <div class="upload-form__col">
        <div class="field">
          <%= form.label :title, class: "field-label" %>
          <%= form.text_field :title, required: true, class: "field-input" %>
        </div>

        <div class="field">
          <%= form.label :description, class: "field-label" %>
          <%= form.text_area :description, rows: 5, class: "field-input" %>
        </div>

        <div class="field">
          <%= form.label :maturity_rating, "Maturity", class: "field-label" %>
          <%= form.select :maturity_rating, Video.maturity_ratings.keys.map { |k| [ k, k ] },
                {}, class: "field-input" %>
        </div>

        <div class="field">
          <%= form.label :visibility, class: "field-label" %>
          <%= form.select :visibility,
                Video.visibilities.keys.map { |k| [ (k == "restricted" ? "Restricted (PIN) — A18" : k.titleize), k ] },
                { selected: "public" }, class: "field-input" %>
        </div>
      </div>

      <%# Right: video file + thumbnail uploads %>
      <div class="upload-form__col">
        <div class="field">
          <%= form.label :file, "Video file", class: "field-label" %>
          <div class="uploader uploader--file" data-controller="file-upload">
            <%= form.file_field :file, required: true, accept: "video/*", class: "uploader__input",
                  data: { "file-upload-target": "input", action: "change->file-upload#change" } %>
            <div class="uploader__prompt">
              <%= icon(:movie) %>
              <span>Choose a video file</span>
            </div>
            <div class="uploader__status">
              <%= icon(:movie) %>
              <span class="uploader__filename" data-file-upload-target="filename"></span>
              <%= icon(:check, class: "uploader__check") %>
            </div>
          </div>
        </div>

        <div class="field">
          <%= form.label :thumbnail, "Thumbnail (optional)", class: "field-label" %>
          <div class="uploader uploader--image" data-controller="file-upload">
            <%= form.file_field :thumbnail, accept: "image/*", class: "uploader__input",
                  data: { "file-upload-target": "input", action: "change->file-upload#change" } %>
            <%= image_tag("", class: "image-preview", alt: "Thumbnail preview",
                  data: { "file-upload-target": "preview" }) %>
            <div class="uploader__prompt">
              <%= icon(:image) %>
              <span>Choose a thumbnail</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%= form.submit "Upload", class: "btn btn-primary btn-block upload-form__submit" %>
  <% end %>
<% end %>
