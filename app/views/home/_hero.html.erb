<%# Hero banner: cycles up to 4 recent movies (FR-004/FR-005). %>
<% if movies.any? %>
  <section class="hero"
           data-controller="hero-carousel"
           data-hero-carousel-interval-value="8000"
           data-action="mouseenter->hero-carousel#pause mouseleave->hero-carousel#resume">
    <% movies.each_with_index do |movie, index| %>
      <div class="hero__slide<%= ' is-active' if index.zero? %>" data-hero-carousel-target="slide">
        <%= poster_image_tag movie.backdrop, movie.backdrop_key,
              alt: movie.title, limit: [1920, 1080], class: "hero__img" %>
        <div class="hero__overlay">
          <h2 class="hero__title"><%= movie.title %></h2>
        </div>
      </div>
    <% end %>
  </section>
<% end %>
