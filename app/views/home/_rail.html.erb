<%# A horizontally-scrolled shelf of poster cards (FR-006/FR-007).
    Hidden entirely when empty (FR-019). When `pagy` + `next_url` are given, the
    end-of-rail lazy Turbo Frame auto-appends the next page (US5); the arrows
    only scroll already-loaded cards. %>
<% if items.any? %>
  <section class="rail" data-controller="rail">
    <div class="rail__head">
      <h2 class="rail__title"><%= title %></h2>
      <div class="rail__arrows">
        <button type="button" class="rail__arrow" data-action="rail#prev" aria-label="Scroll left">‹</button>
        <button type="button" class="rail__arrow" data-action="rail#next" aria-label="Scroll right">›</button>
      </div>
    </div>
    <%= tag.div class: "rail__track", data: { rail_target: "viewport" }, id: local_assigns[:track_id] do %>
      <% if local_assigns[:pagy] %>
        <%= render "shared/paginated_frame",
              key: key, pagy: pagy, items: items,
              card: "home/poster_card", next_url: next_url %>
      <% else %>
        <%= render partial: "home/poster_card", collection: items, as: :item %>
      <% end %>
    <% end %>
  </section>
<% end %>
